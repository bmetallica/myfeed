# ============================================================
# Dockerfile – MyFeed Android-Scraper (noVNC Edition)
# Basis: Python 3.12 Slim + Xvfb + x11vnc + noVNC + Playwright
# ============================================================
FROM python:3.12-slim

# X11-Anzeige, VNC, noVNC und alle Chromium-Systemabhängigkeiten
RUN apt-get update && apt-get install -y --no-install-recommends \
        xvfb \
        x11vnc \
        novnc \
        websockify \
        wget \
        ca-certificates \
        fonts-liberation \
        libappindicator3-1 \
        libasound2 \
        libatk-bridge2.0-0 \
        libatk1.0-0 \
        libcairo2 \
        libcups2 \
        libdbus-1-3 \
        libexpat1 \
        libfontconfig1 \
        libgbm1 \
        libglib2.0-0 \
        libgtk-3-0 \
        libnspr4 \
        libnss3 \
        libpango-1.0-0 \
        libpangocairo-1.0-0 \
        libx11-6 \
        libx11-xcb1 \
        libxcb1 \
        libxcomposite1 \
        libxcursor1 \
        libxdamage1 \
        libxext6 \
        libxfixes3 \
        libxi6 \
        libxrandr2 \
        libxrender1 \
        libxss1 \
        libxtst6 \
        xdg-utils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Chromium-Browser herunterladen
RUN playwright install chromium

COPY scraper.py start.sh ./
RUN chmod +x start.sh

# noVNC-Webinterface (einmaliges Login via Browser)
EXPOSE 6080

CMD ["/app/start.sh"]
