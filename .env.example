# ============================================================
# MyFeed – Umgebungsvariablen
# Kopiere diese Datei nach .env und passe die Werte an.
# Die .env-Datei enthält Secrets – NIEMALS einchecken!
# ============================================================

# ----- API Gateway -----
# Port, auf dem das FastAPI-Gateway von außen erreichbar ist
GATEWAY_PORT=8000

# Langer, zufällig generierter Bearer-Token für alle Clients.
# Erstellen mit: python3 -c "import secrets; print(secrets.token_hex(32))"
API_BEARER_TOKEN=<dein-sicherer-token>

# ----- Android-Scraper -----
# Auf true setzen, um den Google-MyActivity-Scraper zu aktivieren
ENABLE_ANDROID_SCRAPER=false

# Scrape-Intervall in Sekunden (Standard: 300 = 5 Minuten)
SCRAPER_INTERVAL_SECS=300

# Debug-Protokoll für Tag-Generierung (true = aktiviert, false = keine Debug-Dateien schreiben)
ENABLE_DEBUG_LOGS=true

# ----- Web-Frontend -----
# Port, auf dem das Admin-Dashboard erreichbar ist
FRONTEND_PORT=7999

# ----- PostgreSQL / pgvector -----
POSTGRES_USER=myfeed
POSTGRES_PASSWORD=<dein-sicheres-datenbankpasswort>
POSTGRES_DB=myfeed
